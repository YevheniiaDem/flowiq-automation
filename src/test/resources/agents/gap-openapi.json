{
  "openapi": "3.0.1",
  "paths": {
    "/auth/login": {
      "post": {
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/me": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/tasks": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/tasks/{id}": {
      "put": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "204": { "description": "No Content" } }
      }
    },
    "/imports/upload": {
      "post": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/dashboard/summary": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
