<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Flowiq Security Suite" parallel="false" verbose="1">
    <listeners>
        <listener class-name="com.flowiq.listeners.AllureListener"/>
        <listener class-name="com.flowiq.listeners.TestExecutionListener"/>
        <listener class-name="com.flowiq.listeners.InfrastructureRetryTransformer"/>
    </listeners>

    <test name="Security Tests">
        <groups>
            <run>
                <include name="security"/>
            </run>
        </groups>
        <packages>
            <package name="com.flowiq.api.security"/>
        </packages>
    </test>
</suite>
