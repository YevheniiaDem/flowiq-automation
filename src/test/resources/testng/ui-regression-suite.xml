<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Flowiq UI Regression Suite" parallel="methods" thread-count="3" verbose="1">
    <listeners>
        <listener class-name="com.flowiq.listeners.AllureListener"/>
        <listener class-name="com.flowiq.listeners.TestExecutionListener"/>
        <listener class-name="com.flowiq.listeners.InfrastructureRetryTransformer"/>
    </listeners>

    <test name="UI Regression Tests">
        <groups>
            <run>
                <include name="ui-regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.flowiq.ui.regression"/>
        </packages>
    </test>
</suite>
