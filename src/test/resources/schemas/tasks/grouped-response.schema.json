{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskListResponse",
  "type": "object",
  "required": ["today", "upcoming", "overdue", "completed"],
  "properties": {
    "today": { "type": "array", "items": { "$ref": "#/definitions/task" } },
    "upcoming": { "type": "array", "items": { "$ref": "#/definitions/task" } },
    "overdue": { "type": "array", "items": { "$ref": "#/definitions/task" } },
    "completed": { "type": "array", "items": { "$ref": "#/definitions/task" } }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "title", "type", "priority", "status"],
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "type": { "type": "string", "enum": ["TAX", "REPORTING", "BUSINESS", "CUSTOM", "SYSTEM"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "COMPLETED", "OVERDUE"] },
        "dueDate": { "type": ["string", "null"] },
        "completedAt": { "type": ["string", "null"] },
        "createdAt": { "type": ["string", "null"] },
        "overdue": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
