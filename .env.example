# Flowiq Docker Compose — copy to .env and adjust if needed

# PostgreSQL
POSTGRES_DB=flowiq
POSTGRES_USER=flowiq
POSTGRES_PASSWORD=flowiq123
POSTGRES_PORT=5432

# Application ports (host)
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Frontend build-time API URL (browser on host uses localhost)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Backend security (change in production)
JWT_SECRET=flowiq-dev-secret-key-change-in-production-min-256-bits-long!!

# Automation credentials (demo user seeded by backend)
TEST_USER_EMAIL=demo@flowiq.ai
TEST_USER_PASSWORD=demo123

# Test suite profile: api-smoke | contract | ui-smoke | api-regression | smoke
TEST_PROFILE=api-smoke

MAVEN_OPTS=-Xmx1024m

# --- Ephemeral CI (docker-compose.ci.yml) ---
# COMPOSE_PROJECT_NAME=flowiq-ci-local
# BACKEND_CONTEXT=./flowiq-backend
# FRONTEND_CONTEXT=./flowiq-frontend
# Optional Compose profile: mailhog | minio | redis
# COMPOSE_PROFILES=

# --- GHCR Docker cache (CI) ---
# GHCR_REGISTRY=ghcr.io
# GHCR_IMAGE_OWNER=your-github-org-lowercase
# BACKEND_IMAGE=ghcr.io/your-org/flowiq-backend:ci-<git-sha>
# FRONTEND_IMAGE=ghcr.io/your-org/flowiq-frontend:ci-<git-sha>
# CI_SKIP_GHCR_PULL=false
